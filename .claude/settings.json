{
  "model": "claude-sonnet-4-6",
  "effort": "high",
  "autoName": true,
  "outputStyle": "default",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(git *)",
      "Edit(src/**)",
      "Write(src/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{"type": "command", "command": "npm run lint --silent || true"}]
      }
    ],
    "PostCompact": [
      {
        "type": "command",
        "command": "mkdir -p .claude/notes && echo \"$CLAUDE_COMPACT_SUMMARY\" > .claude/notes/session-$(date +%Y%m%d-%H%M).md"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "osascript -e 'tell application \"Messages\" to send \"Claude Code done: $CLAUDE_SESSION_NAME\" to buddy \"$TYLER_IMESSAGE_NUMBER\" of service \"iMessage\"' 2>/dev/null || true"
      }
    ]
  }
}
